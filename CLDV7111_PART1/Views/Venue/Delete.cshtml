@model CLDV7111_PART1.Models.Venue

<h2>Delete Venue</h2>

<!-- Confirmation message showing which venue is being deleted -->
<p>
    Are you sure you want to delete
    <strong>@Model.VenueName</strong>?
</p>

<!-- Form posts to DeleteConfirmed action in VenueController -->
<form asp-action="DeleteConfirmed">
    <!-- Hidden field to pass the VenueId to the controller -->
    <input type="hidden" asp-for="VenueId" />

    <!-- Delete button: submits the form and deletes the venue -->
    <button type="submit" class="btn btn-danger">Delete</button>

    <!-- Cancel button: redirects back to the Index page without deleting -->
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>