@model CLDV7111_PART1.Models.Venue

<h2>Edit Venue</h2>

<!-- Venue edit form -->
<form asp-action="Edit">
    <!-- Hidden field to pass the VenueId to the controller -->
    <input type="hidden" asp-for="VenueId" />

    <!-- Input field for Venue Name -->
    <div class="form-group">
        <label>Venue Name</label>
        <input asp-for="VenueName" class="form-control" />
    </div>

    <!-- Input field for Venue Location -->
    <div class="form-group">
        <label>Location</label>
        <input asp-for="Location" class="form-control" />
    </div>

    <!-- Input field for Venue Capacity -->
    <div class="form-group">
        <label>Capacity</label>
        <input asp-for="Capacity" class="form-control" />
    </div>

    <!-- Input field for Venue Image URL -->
    <div class="form-group">
        <label>Image URL</label>
        <input asp-for="ImageUrl" class="form-control" />
    </div>

    <!-- Update button to submit the form -->
    <button type="submit" class="btn btn-primary">Update</button>
</form>