@model CLDV7111_PART1.Models.Event

<h2>Event Details</h2>

<!-- Display the name of the event -->
<p><strong>Name:</strong> @Model.EventName</p>

<!-- Display the date of the event in short date format -->
<p><strong>Date:</strong> @Model.EventDate.ToShortDateString()</p>

<!-- Display the description of the event -->
<p><strong>Description:</strong> @Model.Description</p>

<!-- Display the venue name associated with the event -->
<p><strong>Venue:</strong> @Model.VenueName</p>