@model CLDV7111_PART1.Models.Event

<h2>Edit Event</h2>

<!-- Event edit form -->
<form asp-action="Edit" method="post">
    <!-- Hidden field to pass the EventId to the controller -->
    <input type="hidden" asp-for="EventId" />

    <!-- Input field for Event Name -->
    <div class="form-group mb-3">
        <label asp-for="EventName" class="form-label">Event Name</label>
        <input asp-for="EventName" class="form-control" />
        <span asp-validation-for="EventName" class="text-danger"></span>
    </div>

    <!-- Input field for Event Date -->
    <div class="form-group mb-3">
        <label asp-for="EventDate" class="form-label">Date</label>
        <input asp-for="EventDate" type="date" class="form-control" />
        <span asp-validation-for="EventDate" class="text-danger"></span>
    </div>

    <!-- Input field for Event Description -->
    <div class="form-group mb-3">
        <label asp-for="Description" class="form-label">Description</label>
        <input asp-for="Description" class="form-control" />
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <!-- Input field for Venue Name -->
    <div class="form-group mb-3">
        <label asp-for="VenueName" class="form-label">Venue</label>
        <input asp-for="VenueName" class="form-control" />
        <span asp-validation-for="VenueName" class="text-danger"></span>
    </div>

    <!-- Update button to submit the form -->
    <button type="submit" class="btn btn-primary">Update</button>

    <!-- Cancel button to return to the Index page -->
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>